#!/usr/bin/env bash
# android-file-lock: Execute a command while holding a file lock (Cross-platform)
# Usage: android-file-lock <lockfile> <command> [args...]
set -euo pipefail

LOCKFILE="${1:?Usage: android-file-lock <lockfile> <command> [args...]}"
shift
CMD=("$@")

# Use Python for atomic directory-based locking
PYTHON=$(command -v python3 2>/dev/null || command -v python 2>/dev/null || true)

if [ -z "$PYTHON" ]; then
  echo "ERROR: python3/python not found, required for atomic locking" >&2
  exit 1
fi

"$PYTHON" -c "
import os
import sys
import time
import subprocess

lock_dir = sys.argv[1] + '.lock.d'
pid_file = os.path.join(lock_dir, 'pid')
retries = 30
interval = 0.1

def acquire_lock():
    for _ in range(retries):
        try:
            os.mkdir(lock_dir)
            with open(pid_file, 'w') as f:
                f.write(str(os.getpid()))
            return True
        except FileExistsError:
            # Check if holder is still alive
            try:
                if os.path.exists(pid_file):
                    with open(pid_file, 'r') as f:
                        old_pid = int(f.read().strip())
                    try:
                        os.kill(old_pid, 0)
                    except (OSError, ValueError):
                        # Holder is dead, clean up
                        import shutil
                        shutil.rmtree(lock_dir, ignore_errors=True)
                        continue
            except Exception:
                pass
            time.sleep(interval)
    return False

if not acquire_lock():
    print(f'ERROR: could not acquire lock on {sys.argv[1]} (timeout 3s)', file=sys.stderr)
    sys.exit(98)

try:
    res = subprocess.run(sys.argv[2:])
    sys.exit(res.returncode)
finally:
    import shutil
    shutil.rmtree(lock_dir, ignore_errors=True)
" "$LOCKFILE" "${CMD[@]}"
