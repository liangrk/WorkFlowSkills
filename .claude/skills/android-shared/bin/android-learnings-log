#!/bin/bash
# android-learnings-log: Append a learning entry
# Usage: android-learnings-log '<json>'
set -euo pipefail

# Python3/python compatibility
PYTHON=$(command -v python3 2>/dev/null || command -v python 2>/dev/null || true)
if [ -z "$PYTHON" ]; then echo "ERROR: python3/python not found" >&2; exit 1; fi

INPUT="$1"
if [ -z "$INPUT" ]; then echo "Usage: android-learnings-log '<json>'" >&2; exit 1; fi

# Validate JSON
echo "$INPUT" | "$PYTHON" -c "import sys,json; json.loads(sys.stdin.read())" 2>/dev/null || { echo "ERROR: Invalid JSON" >&2; exit 1; }

# Compute slug
SLUG=$(git remote get-url origin 2>/dev/null | sed 's|.*/||;s|\.git$||;s|/$||' | tail -1)
[ -z "$SLUG" ] && SLUG=$(basename "$(pwd)")
[ -z "$SLUG" ] && { echo "ERROR: Cannot determine project slug" >&2; exit 1; }

DIR="$HOME/.android-skills/projects/$SLUG"
mkdir -p "$DIR"

# Auto-inject timestamp if missing (avoid grep -q which conflicts with pipefail)
HAS_TS=$(echo "$INPUT" | "$PYTHON" -c "import sys,json; d=json.loads(sys.stdin.read()); print('yes' if 'ts' in d else 'no')" 2>/dev/null || echo "no")
if [ "$HAS_TS" != "yes" ]; then
  TS=$(date -u +%Y-%m-%dT%H:%M:%SZ)
  INPUT=$(echo "$INPUT" | "$PYTHON" -c "import sys,json; d=json.loads(sys.stdin.read()); d['ts']='$TS'; print(json.dumps(d))")
fi

echo "$INPUT" >> "$DIR/learnings.jsonl"
echo "OK: learning logged to $DIR/learnings.jsonl"
