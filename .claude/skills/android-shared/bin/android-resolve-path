#!/usr/bin/env bash
# android-resolve-path — 智能路径解析器,解决 Windows/Linux 跨平台调用问题
# 用法: source "$(android-resolve-path)"  或  SHARED_BIN=$(android-resolve-path)
# 自动检测:
#   1. git worktree 根目录
#   2. 当前脚本实际位置
#   3. 备用位置 (~/.claude/skills)
# 输出: SHARED_BIN 的绝对路径

set -euo pipefail

# 策略 1: 通过 git worktree 找主项目根 (解决多 worktree 隔离问题)
# git worktree list 的第一行始终是 main worktree
_MAIN_WORKTREE=$(git worktree list 2>/dev/null | head -1 | awk '{print $1}')

if [ -n "$_MAIN_WORKTREE" ] && [ -d "$_MAIN_WORKTREE/.claude/skills/android-shared/bin" ]; then
  SHARED_BIN="$_MAIN_WORKTREE/.claude/skills/android-shared"
  echo "$SHARED_BIN"
  exit 0
fi

# 策略 2: 通过 git 查找当前 worktree 根
_PROJECT_ROOT=$(git rev-parse --show-toplevel 2>/dev/null || true)
if [ -n "$_PROJECT_ROOT" ] && [ -d "$_PROJECT_ROOT/.claude/skills/android-shared/bin" ]; then
  SHARED_BIN="$_PROJECT_ROOT/.claude/skills/android-shared"
  echo "$SHARED_BIN"
  exit 0
fi

# 其次使用脚本实际位置 ( $_SCRIPT_DIR 本身就是 bin 目录,需要返回上级)
if [ -d "$_SCRIPT_DIR" ]; then
  SHARED_BIN="$(dirname "$_SCRIPT_DIR")"
  echo "$SHARED_BIN"
  # 添加 bin 到 PATH
  case ":${PATH:-}:" in
    *:"$SHARED_BIN/bin":*) ;;
    *) export PATH="$SHARED_BIN/bin:$PATH" ;;
  esac
  exit 0
fi

# 最后回退到用户目录 (返回不含 /bin 的路径)
if [ -d "$HOME/.claude/skills/android-shared/bin" ]; then
  SHARED_BIN="$HOME/.claude/skills/android-shared"
  echo "$SHARED_BIN"
  # 添加 bin 到 PATH
  case ":${PATH:-}:" in
    *:"$SHARED_BIN/bin":*) ;;
    *) export PATH="$SHARED_BIN/bin:$PATH" ;;
  esac
  exit 0
fi

echo "ERROR: android-shared skills not found" >&2
exit 1
