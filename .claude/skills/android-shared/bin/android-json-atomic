#!/usr/bin/env bash
# android-json-atomic: Write JSON to a file atomically
# Usage: echo '<json>' | android-json-atomic <filepath>
set -euo pipefail

PYTHON=$(command -v python3 2>/dev/null || command -v python 2>/dev/null || true)
if [ -z "$PYTHON" ]; then
  echo "ERROR: python3/python not found" >&2
  exit 1
fi

TARGET="${1:?Usage: android-json-atomic <filepath>}"
TARGET_DIR=$(dirname "$TARGET")
mkdir -p "$TARGET_DIR"

# Read from stdin and validate
INPUT=$(cat)

# Atomic update logic
"$PYTHON" -c "
import sys
import json
import os
import tempfile

target = sys.argv[1]
target_dir = os.path.dirname(target)

try:
    # Read and validate JSON
    raw_data = sys.stdin.read()
    if not raw_data.strip():
        print('ERROR: empty input', file=sys.stderr)
        sys.exit(1)
        
    data = json.loads(raw_data)
    validated = json.dumps(data, indent=2, ensure_ascii=False)
    
    # Write to temp file in the same directory
    fd, tmp_path = tempfile.mkstemp(dir=target_dir, prefix='.atomic-', suffix='.tmp')
    try:
        with os.fdopen(fd, 'w', encoding='utf-8') as f:
            f.write(validated)
        
        # Atomic rename
        if os.path.exists(target):
            # On Windows, os.rename fails if target exists
            if os.name == 'nt':
                os.replace(tmp_path, target)
            else:
                os.rename(tmp_path, target)
        else:
            os.rename(tmp_path, target)
            
        print(f'OK: {target} written atomically')
    except Exception as e:
        if os.path.exists(tmp_path):
            os.remove(tmp_path)
        raise e
        
except json.JSONDecodeError as e:
    print(f'ERROR: invalid JSON: {e}', file=sys.stderr)
    sys.exit(1)
except Exception as e:
    print(f'ERROR: {e}', file=sys.stderr)
    sys.exit(1)
" "$TARGET" <<< "$INPUT"
